# ─── Supabase ───────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
# NEXT_PUBLIC_* vars are exposed to the browser. The service role key MUST NOT
# be exposed — it bypasses Row Level Security and is only used in server code.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── HubSpot OAuth App ──────────────────────────────────────────────────────
# developers.hubspot.com → Apps → your app → Auth tab.
# HUBSPOT_CLIENT_SECRET doubles as the HMAC key used to verify webhook
# signatures (X-HubSpot-Signature-v3). HubSpot does NOT provide a separate
# webhook secret — see https://developers.hubspot.com/docs/apps/legacy-apps/authentication/validating-requests
HUBSPOT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HUBSPOT_CLIENT_SECRET=yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy

# Must match a Redirect URL registered on the HubSpot app (Auth tab).
# Dev (ngrok):   https://xxxx.ngrok-free.app/api/hubspot/callback
# Prod (Vercel): https://tu-app.vercel.app/api/hubspot/callback
# Note: this is DIFFERENT from /auth/callback (Supabase magic link).
HUBSPOT_REDIRECT_URI=https://tu-app.vercel.app/api/hubspot/callback

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# platform.openai.com → API Keys. Used for gpt-4o-mini (insights, search, chat)
# and text-embedding-3-small (RAG embeddings).
OPENAI_API_KEY=sk-...

# ─── App ────────────────────────────────────────────────────────────────────
# Public base URL with no trailing slash. In dev pointing through ngrok, use
# the ngrok URL so OAuth redirects and email links resolve correctly.
NEXT_PUBLIC_APP_URL=https://tu-app.vercel.app

# ─── Cron ───────────────────────────────────────────────────────────────────
# Bearer token verified by /api/cron/sync. Vercel injects it automatically in
# the Authorization header when invoking scheduled cron jobs.
CRON_SECRET=replace-with-a-long-random-string

# ─── HubSpot seed script (dev-only) ─────────────────────────────────────────
# Private app token used by scripts/seed-hubspot.ts to populate the Sandbox
# with 50 contacts. Settings → Integrations → Private Apps → create app.
# Not used at runtime — only for local seeding.
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-...
