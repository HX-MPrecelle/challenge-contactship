# ─────────────────────────────────────────────────────────────────────────────
# ContactShip — environment variables
# Copy this file to `.env.local` at the repo root and fill in the real values.
# See SETUP.md for step-by-step instructions on how to obtain each value.
# ─────────────────────────────────────────────────────────────────────────────

# App URL (client + redirect URIs). For local dev: http://localhost:3000.
# In production this is your Vercel URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → Data API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Project Settings → Data API → service_role (NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Database (Drizzle) ───────────────────────────────────────────────────────
# Both connection strings live in Supabase → Project Settings → Database.
# DATABASE_URL points to the transaction pooler (port 6543) — used at runtime.
# DIRECT_URL points to the direct connection (port 5432) — used for migrations.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── HubSpot ──────────────────────────────────────────────────────────────────
# Developer account → your app → Auth tab.
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/api/hubspot/callback

# HubSpot signs webhook deliveries with the app's client secret. Until you
# enable webhooks in the app settings, you can leave this unset.
HUBSPOT_WEBHOOK_SECRET=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Token encryption ─────────────────────────────────────────────────────────
# 32-byte random key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Used to AES-256-GCM-encrypt HubSpot access/refresh tokens at rest.
ENCRYPTION_KEY=
